{
  "name": "lyriclytic",
  "version": "1.2.0",
  "private": true,
  "engines": {
    "node": ">=20.19.0 <21 || >=22.12.0"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "tsc --noEmit",
    "preview": "vite preview",
    "test": "vitest",
    "test:coverage": "vitest run --coverage --maxWorkers=1 --coverage.thresholds.lines=80 --coverage.thresholds.statements=80 --coverage.thresholds.functions=80 --coverage.thresholds.branches=80",
    "audit:prod": "npm audit --omit=dev --audit-level=moderate",
    "audit:all": "npm audit --audit-level=high",
    "test:run": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "update:suno-catalog": "node scripts/update-suno-prompt-catalog.mjs",
    "enrich:suno-catalog": "node scripts/enrich-suno-prompt-catalog.mjs",
    "enrich:suno-important": "node scripts/enrich-suno-important-sections.mjs",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "2.6.0",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "monaco-editor": "0.55.1",
    "react": "^18.3.1",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dnd-touch-backend": "^16.0.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "6.30.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tauri-apps/cli": "^2.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "5.2.0",
    "@vitest/coverage-v8": "^4.1.2",
    "esbuild": "0.28.1",
    "jsdom": "^29.0.1",
    "typescript": "^5.4.0",
    "vite": "7.3.6",
    "vitest": "^4.1.2"
  },
  "overrides": {
    "dompurify": "3.4.11",
    "postcss": "8.5.16",
    "undici": "7.28.0"
  }
}
